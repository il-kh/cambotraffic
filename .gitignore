# file based on github/gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
.pytest_cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Documentation
docs/
*.xlsx

# Media files
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.mp4
*.avi
*.mov
*.mkv
*.wav
*.mp3
*.flac
*.ogg
*.webm

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# Environments
.pixi
*.egg-info
.env
.env.local
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
db_data/

# Spyder project settings
.spyderproject
.spyproject

# VScode
.vscode

# PyCharm
.idea

# sphinx gallery output
gistim/examples/data/
# pixi environments
.pixi/*
!.pixi/config.toml
